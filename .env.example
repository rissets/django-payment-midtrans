# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*,localhost,127.0.0.1

# Midtrans Credentials (get from https://dashboard.sandbox.midtrans.com)
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx
MIDTRANS_MERCHANT_ID=G000000000
MIDTRANS_IS_PRODUCTION=False

# Midtrans Notification URL — your public URL for webhooks
# Use ngrok/cloudflared to expose localhost, e.g.:
#   ngrok http 8000
# Then set it like:
MIDTRANS_NOTIFICATION_URL=https://your-ngrok-url.ngrok-free.app/midtrans/api/notification/

# Celery (optional)
CELERY_BROKER_URL=memory://
